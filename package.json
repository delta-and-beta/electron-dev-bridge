{
  "name": "electron-dev-bridge",
  "version": "0.3.0",
  "description": "Expose Electron IPC handlers as MCP tools for Claude Code, with 33 built-in CDP tools for DOM automation, screenshots, console/network capture, and multi-window support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "electron-mcp": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test dist/**/*.test.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "electron",
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "cdp",
    "chrome-devtools-protocol",
    "ipc",
    "testing",
    "automation",
    "desktop-app"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/delta-and-beta/electron-dev-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/delta-and-beta/electron-dev-bridge/issues"
  },
  "homepage": "https://github.com/delta-and-beta/electron-dev-bridge#readme",
  "author": "",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chrome-remote-interface": "^0.34.0",
    "tsx": "^4.21.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "peerDependencies": {
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "skills",
    "LICENSE",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
